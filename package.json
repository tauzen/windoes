{
  "name": "windoes",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "husky",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "npm run lint && npm run test:unit && npm run test:integration",
    "test:unit": "node --test tests/node/reducer.test.js tests/node/browser-url.test.js",
    "test:integration": "node --test --test-concurrency=1 tests/node/playwright-integration.test.js",
    "test:virtual-fs": "node tests/test-virtual-fs.js",
    "test:ascii-runner": "cd windoes/public/applications/ascii-runner && node tests/test-ascii-runner.js",
    "test:minesweeper": "cd windoes/public/applications/minesweeper && node tests/test-minesweeper.js",
    "test:solitaire": "cd windoes/public/applications/solitaire && node tests/test-solitaire.js",
    "test:winamp-player": "cd windoes/public/applications/winamp-player && node tests/test-winamp-player.js",
    "test:apps": "npm run test:ascii-runner && npm run test:minesweeper && npm run test:solitaire && npm run test:winamp-player",
    "test:all": "npm test && npm run test:apps",
    "install:apps": "cd windoes/public/applications/ascii-runner && npm install && cd ../minesweeper && npm install && cd ../solitaire && npm install && cd ../winamp-player && npm install"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@vitejs/plugin-react": "^5.0.4",
    "eslint": "^9.25.1",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "playwright": "^1.52.0",
    "prettier": "^3.5.3",
    "vite": "^6.3.1"
  },
  "lint-staged": {
    "*.{js,jsx,mjs,cjs,json,md,css}": "prettier --write"
  }
}
