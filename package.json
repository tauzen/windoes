{
  "name": "windoes",
  "private": true,
  "workspaces": [
    "windoes/public/applications/ascii-runner",
    "windoes/public/applications/minesweeper",
    "windoes/public/applications/paint",
    "windoes/public/applications/solitaire",
    "windoes/public/applications/winamp-player"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "husky",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "npm run lint && npm run test:unit && npm run test:integration",
    "test:unit": "node --test tests/node/reducer.test.js tests/node/browser-url.test.js tests/node/explorer-navigation.test.js",
    "test:integration": "node --test --test-concurrency=1 tests/node/playwright-integration.test.js",
    "test:a11y": "node tests/test-axe-accessibility.js",
    "test:virtual-fs": "node tests/test-virtual-fs.js",
    "test:ascii-runner": "npm run -w ./windoes/public/applications/ascii-runner test",
    "test:minesweeper": "npm run -w ./windoes/public/applications/minesweeper test",
    "test:paint": "npm run -w ./windoes/public/applications/paint test",
    "test:solitaire": "npm run -w ./windoes/public/applications/solitaire test",
    "test:winamp-player": "npm run -w ./windoes/public/applications/winamp-player test",
    "test:apps": "npm run test:ascii-runner && npm run test:minesweeper && npm run test:paint && npm run test:solitaire && npm run test:winamp-player",
    "test:all": "npm run typecheck && npm test && npm run test:apps"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@eslint/js": "^9.25.1",
    "@vitejs/plugin-react": "^5.0.4",
    "eslint": "^9.25.1",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "playwright": "^1.52.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "vite": "^6.3.1"
  },
  "lint-staged": {
    "*.{js,jsx,mjs,cjs,json,md,css}": "prettier --write"
  }
}
